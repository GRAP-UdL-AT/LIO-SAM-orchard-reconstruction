<launch>

  <!--
    LIO-SAM orchard reconstruction launch file.

    This file is a adaptation of the original LIO-SAM run.launch.
    It only adds a configurable parameter file argument so that different
    sensor-specific YAML files can be selected without renaming them to
    config/params.yaml.

    Example:
      roslaunch lio_sam run_orchard.launch config_file:=params_ouster.yaml
      roslaunch lio_sam run_orchard.launch config_file:=params_livox.yaml
  -->

  <arg name="project" default="lio_sam"/>
  <arg name="config_file" default="params_ouster.yaml"/>

  <!-- Parameters -->
  <rosparam file="$(find lio_sam)/config/$(arg config_file)" command="load" />

  <!-- LOAM -->
  <include file="$(find lio_sam)/launch/include/module_loam.launch" />

  <!-- Robot State TF -->
  <include file="$(find lio_sam)/launch/include/module_robot_state_publisher.launch" />

  <!-- Navsat -->
  <include file="$(find lio_sam)/launch/include/module_navsat.launch" />

  <!-- Rviz -->
  <include file="$(find lio_sam)/launch/include/module_rviz.launch" />

</launch>
